{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ticmsg",
  "version": "0.1.0",
  "identifier": "com.ticmsg.secureapp",
  "build": {
    "frontendDist": "../ui",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TicMsg",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "exe", "dmg", "app", "deb", "appimage", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {}
  }
}
